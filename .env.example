# Copy to .env and fill in real values. Never commit the real .env.

ANTHROPIC_API_KEY=

# Persistence backend: "supabase", "postgres", or unset (in-memory, local/dev/test default)
DB_BACKEND=

# DATABASE_URL takes priority over the two backend-specific vars below, if set.
# Example shape only - never commit a real password here, .env.example is public:
# DATABASE_URL=postgresql://postgres:<password>@localhost:5433/<dbname>
DATABASE_URL=

# Supabase's own Postgres connection string (Project Settings > Database > Connection string)
SUPABASE_DB_DSN=

POSTGRES_DSN=

# Optional shared-secret for GET /api/v1/audit/run (costs real LLM $ per call).
# If unset, the endpoint is unauthenticated (fine for localhost/dev only). If set,
# callers must send a matching X-Audit-Api-Key header.
AUDIT_API_KEY=
